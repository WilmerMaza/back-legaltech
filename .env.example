# Copia a .env y ajusta. No subas .env al repositorio.
DATABASE_URL="postgresql://postgres:TU_PASSWORD@localhost:5432/legaltech"

# JWT — sesión estricta: access 15 min, refresh máx. 1 día, tope absoluto 24h, idle 30 min
JWT_ACCESS_SECRET="genera-un-secreto-largo-aleatorio"
JWT_REFRESH_SECRET="genera-otro-secreto-largo-aleatorio"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="1d"
JWT_SESSION_MAX_AGE="1d"
JWT_IDLE_TIMEOUT="30m"
# Ventana de gracia (segundos) para refresh concurrente tras rotación (HMR / Strict Mode)
JWT_REFRESH_GRACE_SECONDS="30"

# Zona horaria para "hoy" en el cálculo de días en mora (fecha civil). Ver BACKEND_API §6.5.1.
BUSINESS_TIMEZONE="America/Bogota"

# Recordatorios de pago por email (Gmail / Google Workspace SMTP)
# GMAIL_USER: cuenta con la que autenticas SMTP (App Password de esa cuenta)
GMAIL_USER="cuenta-autenticacion@abogadosdigitales.com.co"
GMAIL_PASS="app-password-de-16-caracteres-sin-espacios"
# GMAIL_FROM: remitente visible (alias); si no se define, usa GMAIL_USER
GMAIL_FROM="notificaciones-cartera-abogadosdigitales@abogadosdigitales.com.co"
GMAIL_FROM_NAME="Notificaciones Cartera"
